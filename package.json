{
  "name": "@yksanjo/codex-conductor",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Codex-first cockpit and MCP server for local Codex sessions: read ~/.codex transcripts, group work by status, and drive managed tmux sessions behind an irreversibility gate.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yksanjo/codex-conductor.git"
  },
  "homepage": "https://github.com/yksanjo/codex-conductor#readme",
  "bugs": {
    "url": "https://github.com/yksanjo/codex-conductor/issues"
  },
  "bin": {
    "codex-conductor": "cli.js",
    "codex-cockpit": "server.js",
    "codex-conductor-mcp": "mcp.js",
    "codex-conductor-seat": "seat-server.js",
    "codex-conductor-seat-mcp": "seat-mcp.js"
  },
  "scripts": {
    "start": "node scan.js",
    "serve": "node server.js",
    "mcp": "node mcp.js",
    "seat": "node seat-server.js",
    "seat-mcp": "node seat-mcp.js",
    "test": "node codex.test.js && node policy.test.js && node --check cli.js && node --check scan.js && node --check server.js && node --check mcp.js && node --check manage.js && node --check drive.js && node --check seat.js && node --check seat-server.js && node --check seat-mcp.js"
  },
  "files": [
    "cli.js",
    "scan.js",
    "server.js",
    "ui.html",
    "mcp.js",
    "config.js",
    "seat.js",
    "drive.js",
    "seat-server.js",
    "seat-mcp.js",
    "engine.js",
    "lib.js",
    "manage.js",
    "policy.js",
    "util.js",
    "adapters/codex-code.js",
    "skill/SKILL.md",
    "docs/orchestrator-prompt.md",
    "docs/manual.html",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "codex",
    "codex-cli",
    "codex-code",
    "openai-codex",
    "mcp",
    "tmux",
    "local-first",
    "developer-tools",
    "cli",
    "dashboard",
    "session-monitor"
  ],
